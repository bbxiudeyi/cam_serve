# ============================================================
#  Rust / Cargo
# ============================================================
/target/
**/target/
Cargo.lock
*.rs.bk

# ============================================================
#  Python (serve.py 网页托管)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ============================================================
#  日志 & 运行时产物
# ============================================================
*.log
logs/
*.pid

# ============================================================
#  打包产物(发布用的压缩包)
# ============================================================
*.zip
*.tar
*.tar.gz
*.7z

# ============================================================
#  Windows(项目用 .bat + 摄像头,开发机为 Windows)
# ============================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ============================================================
#  macOS / Linux(顺手覆盖,跨设备协作不脏)
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
*~
.directory

# ============================================================
#  IDE / 编辑器
# ============================================================
# JetBrains (RustRover / CLion / IntelliJ)
.idea/
*.iml
# VS Code(保留 launch.json/extensions.json 这类共享配置的能力,只忽略个人状态)
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
# Visual Studio / Rider
.vs/
*.suo
*.user
*.userprefs

# ============================================================
#  环境变量 & 密钥(别把本地配置推上去)
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key

# ============================================================
#  构建缓存 / 测试覆盖率
# ============================================================
*.profraw
*.profdata
coverage/
